# @flutter_tool: use_swift_package_manager=false

platform :ios, '13.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # هذه الأسطر تجعل السيرفر يبحث عن حزم فلوتر فقط إذا تم توليدها
  flutter_ios_podfile_setup = File.join(File.dirname(File.expand_path(__FILE__)), 'Flutter', 'generated_plugin_pods.rb')
  if File.exist?(flutter_ios_podfile_setup)
    require flutter_ios_podfile_setup
  end

  flutter_install_all_ios_pods File.dirname(File.expand_path(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_allocations(target) if respond_to?(:flutter_additional_ios_allocations)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end
end